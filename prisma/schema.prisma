// Zam.guv — Government Contracting Portal
// 30-minute VP assessment sessions

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         String   // "vp" | "admin"
  passwordHash String
  createdAt    DateTime @default(now())

  // Module progression
  currentModule Int     @default(1)   // 1 = intro, 2 = training, 3 = simulation, 4 = complete
  module1Done   Boolean @default(false)
  module2Done   Boolean @default(false)
  module3Done   Boolean @default(false)

  // Cohort assignment (Feature 4)
  cohortId      String?
  cohort        Cohort?  @relation(fields: [cohortId], references: [id])

  sessions       Session[]
  proposals      Proposal[]
  contractViews  ContractView[]
  tabSwitchEvents TabSwitchEvent[]
}

model Contract {
  id               String   @id @default(cuid())
  solicNumber      String   @unique  // e.g. "FA8617-26-R-0021"
  title            String
  agency           String
  subAgency        String?
  description      String
  requirements     String   // JSON array of key requirements
  naicsCode        String
  setAside         String?  // "8(a)" | "SDVOSB" | "HUBZone" | "WOSB" | "SB" | "Unrestricted"
  valueMin         Float
  valueMax         Float
  dueDate          DateTime
  postedDate       DateTime @default(now())
  pob              String   // Place of performance
  securityClear    String   // "None" | "Secret" | "Top Secret" | "TS/SCI"
  type             String   // "FFP" | "T&M" | "CPFF" | "IDIQ" | "BPA"
  vehicleType      String   @default("Standard")  // "Standard" | "IDIQ" | "OTA" | "GSA" | "SBIR"
  status           String   @default("active") // "active" | "closed" | "awarded"

  proposals     Proposal[]
  contractViews ContractView[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  startedAt DateTime @default(now())
  expiresAt DateTime // startedAt + 30 minutes (or 24h for training)
  locked    Boolean  @default(false)
  lockedAt  DateTime?
  mode        String   @default("assessment") // "assessment" | "training"
  vehicleType String   @default("Standard")  // "Standard" | "IDIQ" | "OTA" | "GSA" | "SBIR"

  // Feature 6: attempt limiting — tracks which login token created this session
  loginToken  String?

  // Feature 7: tab switch tracking
  tabSwitchCount Int @default(0)

  user            User             @relation(fields: [userId], references: [id])
  proposals       Proposal[]
  contractViews   ContractView[]
  tabSwitchEvents TabSwitchEvent[]
}

model Proposal {
  id              String   @id @default(cuid())
  contractId      String
  userId          String
  sessionId       String

  // Proposal content
  executiveSummary   String
  technicalApproach  String
  managementApproach String
  pricingNarrative   String
  pastPerformance    String

  // Pricing
  proposedValue   Float

  // Status
  status          String   @default("draft") // "draft" | "submitted"
  submittedAt     DateTime?
  autoSubmitted   Boolean  @default(false) // true if session expired mid-draft

  // AI Scoring (populated after submission)
  aiScore         Float?   // 0-100
  aiScoreBreakdown String?  // JSON: { technical, management, pricing, past_performance, compliance }
  aiFeedback      String?  // JSON: { strengths, weaknesses, recommendation, feedback }
  aiScoredAt      DateTime?

  // Feature 8: AI-generated interview questions
  aiInterviewQuestions String?  // JSON array of 3-5 question strings

  // Feature 3: Admin score override
  adminScore      Float?
  adminNotes      String?
  adminScoredAt   DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contract Contract @relation(fields: [contractId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  session  Session  @relation(fields: [sessionId], references: [id])

  @@unique([contractId, userId]) // one proposal per contract per VP
}

// Feature 1: Behavioral Analytics — contract view tracking
model ContractView {
  id          String   @id @default(cuid())
  userId      String
  contractId  String
  sessionId   String
  viewedAt    DateTime @default(now())
  timeSpentMs Int?

  user     User     @relation(fields: [userId], references: [id])
  contract Contract @relation(fields: [contractId], references: [id])
  session  Session  @relation(fields: [sessionId], references: [id])

  @@unique([contractId, userId, sessionId])
}

// Feature 4: Cohort grouping
model Cohort {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  users User[]
}

// Feature 7: Tab switch events
model TabSwitchEvent {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  occurredAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])
}
